# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# Snowflake (used by sync jobs)
SNOWFLAKE_ACCOUNT=YL35090.south-central-us.azure
SNOWFLAKE_USER=<user>
SNOWFLAKE_PRIVATE_KEY=<base64-encoded-rsa-private-key>
SNOWFLAKE_PRIVATE_KEY_PASSPHRASE=<passphrase-if-encrypted>
SNOWFLAKE_DATABASE=FO_PROD_DB
SNOWFLAKE_WAREHOUSE=REPORTING_WH
SNOWFLAKE_ROLE=REPORTING_ROLE
SNOWFLAKE_SCHEMA=MARTS

# Power BI Embedded
POWERBI_TENANT_ID=<azure-tenant-id>
POWERBI_CLIENT_ID=<app-registration-client-id>
POWERBI_CLIENT_SECRET=<app-registration-client-secret>
POWERBI_WORKSPACE_ID=<power-bi-workspace-id>

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
